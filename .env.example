# ── FastAPI ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production

# ── Ollama ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_SYSTEM_PROMPT=Eres un asistente de voz amigable y conciso. Responde siempre en el mismo idioma que el usuario. Mantén las respuestas cortas y naturales para conversación de voz.

# ── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── AWS ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ── Amazon Transcribe ────────────────────────────────────
TRANSCRIBE_LANGUAGE_CODE=es-ES
TRANSCRIBE_S3_BUCKET=your-transcribe-bucket

# ── DynamoDB ─────────────────────────────────────────────
DYNAMODB_TABLE_NAME=voice_agent_sessions
DYNAMODB_SESSION_TTL_HOURS=24

# ── AWS Lambda ───────────────────────────────────────────
LAMBDA_CLEANUP_FUNCTION=voice-agent-session-cleanup
